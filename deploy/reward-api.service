[Unit]
Description=Reward FastAPI service
After=network.target

[Service]
WorkingDirectory=/opt/reward
EnvironmentFile=/opt/reward/.env
ExecStart=/opt/reward/.venv/bin/python -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
